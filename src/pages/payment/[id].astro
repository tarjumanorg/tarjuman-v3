---
import Layout from "../../layouts/Layout.astro";
import { createClient } from "../../lib/supabase";
import { actions } from "astro:actions";

const { id } = Astro.params;
const supabase = createClient(Astro);

if (!id) {
    return Astro.redirect("/404");
}

const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect(`/login?redirect=/payment/${id}`);
}

// Handle action result early
const result = Astro.getActionResult(actions.submitTransferProof);
if (result && !result.error && result.data?.success) {
    return Astro.redirect(`/payment/success/${id}`);
}

// Fetch order details
const { data: order, error } = await supabase
    .from("orders")
    .select("*, order_files(*)")
    .eq("id", id)
    .single();

if (error || !order) {
    console.error("Error fetching order:", error);
    return Astro.redirect("/404");
}

// Security: Ensure user owns the order
if (order.user_id !== user.id) {
    return Astro.redirect("/404");
}

// If already paid or pending verification, redirect to success
if (order.payment_status === "paid" || order.payment_status === "pending") {
    return Astro.redirect(`/payment/success/${id}`);
}

function formatPrice(price: number) {
    return new Intl.NumberFormat("id-ID", {
        style: "currency",
        currency: "IDR",
        minimumFractionDigits: 0,
    }).format(price);
}

// The exact amount including the unique_amount 
const paymentAmount = Math.round(order.final_price || 0);
---

<Layout title={`Pembayaran Order #${id?.slice(0, 8)} - Tarjuman`}>
    <div class="container mx-auto py-10 px-4 max-w-2xl">
        <a
            href="/dashboard"
            class="text-sm text-muted-foreground hover:text-primary mb-6 inline-block"
        >
            &larr; Kembali ke Dashboard
        </a>

        <div
            class="rounded-xl border border-border bg-card shadow-lg overflow-hidden"
        >
            <div class="bg-primary/5 p-6 border-b border-border">
                <h1 class="font-serif text-2xl font-bold text-foreground">
                    Instruksi Pembayaran
                </h1>
                <p class="text-muted-foreground text-sm mt-1">
                    Lakukan transfer bank lalu unggah bukti pembayaran Anda.
                </p>
            </div>

            <div class="p-6 space-y-8">
                <!-- Order Summary -->
                <div class="space-y-4">
                    <div class="flex justify-between py-2 border-b border-border/50">
                        <span class="text-muted-foreground">Order ID</span>
                        <span class="font-mono text-sm">{order.id.slice(0, 8)}...</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-border/50">
                        <span class="text-muted-foreground">Estimasi Waktu</span>
                        <span class="font-medium">{order.urgency_days} Hari Kerja</span>
                    </div>
                </div>

                <!-- Total -->
                <div class="flex flex-col items-center justify-center bg-muted/50 p-6 rounded-lg text-center space-y-2 relative overflow-hidden group">
                    <div class="absolute inset-0 bg-primary/5"></div>
                    <span class="font-semibold text-lg relative z-10">Total Transfer</span>
                    <div class="flex items-center gap-3 relative z-10">
                        <span class="font-bold text-4xl text-primary">{formatPrice(paymentAmount)}</span>
                        <button 
                            class="copy-btn p-2 rounded-full bg-white/80 hover:bg-white text-primary shadow-sm transition-all hover:scale-110 active:scale-95 border border-primary/10"
                            title="Salin nominal transfer"
                            data-copy={paymentAmount.toString()}
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon hidden text-green-600"><path d="M20 6 9 17l-5-5"/></svg>
                        </button>
                    </div>
                    <span class="text-sm text-muted-foreground mt-2 bg-primary/10 px-4 py-1.5 rounded-full relative z-10 font-medium">
                        Mohon transfer <strong class="text-foreground">tepat</strong> hingga 3 digit terakhir.
                    </span>
                </div>

                <!-- Bank Accounts -->
                <div class="space-y-4">
                    <h3 class="font-semibold border-b pb-2">Pilih Rekening Tujuan</h3>
                    
                    <div class="grid gap-4 sm:grid-cols-2">
                        <!-- BRI -->
                        <div class="border rounded-lg p-4 bg-background hover:border-primary/50 transition-colors relative group">
                            <div class="flex items-center justify-between mb-2">
                                <div class="text-xs text-muted-foreground font-bold uppercase bg-slate-100 px-2 py-0.5 rounded">BANK BRI</div>
                            </div>
                            <div class="flex items-center justify-between gap-2">
                                <div class="font-mono text-xl font-bold tracking-wider text-slate-800 mb-1 account-number" data-account="546201008338537">5462 0100 8338 537</div>
                                <button 
                                    class="copy-btn p-2 rounded-md hover:bg-slate-100 text-muted-foreground transition-colors group-hover:text-primary"
                                    title="Salin nomor rekening"
                                    data-copy="546201008338537"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon hidden text-green-600"><path d="M20 6 9 17l-5-5"/></svg>
                                </button>
                            </div>
                            <div class="text-sm text-muted-foreground">a.n Muhammad Siddiq</div>
                        </div>
                        
                        <!-- BSI -->
                        <div class="border rounded-lg p-4 bg-background hover:border-primary/50 transition-colors relative group">
                            <div class="flex items-center justify-between mb-2">
                                <div class="text-xs text-muted-foreground font-bold uppercase bg-slate-100 px-2 py-0.5 rounded">BANK BSI</div>
                            </div>
                            <div class="flex items-center justify-between gap-2">
                                <div class="font-mono text-xl font-bold tracking-wider text-slate-800 mb-1 account-number" data-account="429261150">4292 6115 0</div>
                                <button 
                                    class="copy-btn p-2 rounded-md hover:bg-slate-100 text-muted-foreground transition-colors group-hover:text-primary"
                                    title="Salin nomor rekening"
                                    data-copy="429261150"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon hidden text-green-600"><path d="M20 6 9 17l-5-5"/></svg>
                                </button>
                            </div>
                            <div class="text-sm text-muted-foreground">a.n Muhammad Siddiq</div>
                        </div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="relative py-2">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-dashed border-border/60"></div>
                    </div>
                </div>

                <!-- Upload Form -->
                <div class="space-y-4">
                    <h3 class="font-semibold">Konfirmasi Pembayaran</h3>
                    <p class="text-sm text-muted-foreground mb-4">
                        Setelah berhasil transfer, silakan unggah screenshot atau foto resi sebagai bukti pembayaran.
                    </p>

                    {result?.error?.message && (
                        <div class="p-4 text-sm font-medium text-destructive bg-destructive/10 border border-destructive/20 rounded-lg flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            Gagal mengunggah bukti: {result.error.message}
                        </div>
                    )}

                    <form 
                        method="POST" 
                        action={actions.submitTransferProof} 
                        enctype="multipart/form-data" 
                        class="space-y-4 bg-slate-50 p-5 rounded-xl border border-slate-100"
                    >
                        <input type="hidden" name="orderId" value={order.id} />
                        
                        <div class="grid w-full items-center gap-2">
                            <label for="proof" class="text-sm font-bold leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-slate-700">
                                Unggah Bukti Transfer <span class="text-destructive">*</span>
                            </label>
                            <input 
                                id="proof" 
                                name="proof" 
                                type="file" 
                                accept="image/jpeg,image/png,image/webp,.pdf" 
                                required
                                class="flex w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm file:border-0 file:bg-primary/10 file:font-semibold file:text-primary file:mr-3 file:py-1 file:px-3 file:rounded-full placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 hover:border-primary/50 transition-colors cursor-pointer text-slate-600" 
                            />
                            <p class="text-xs text-muted-foreground">Format JPG, PNG, atau PDF. Maksimal 5MB.</p>
                        </div>

                        <button 
                            type="submit" 
                            class="w-full inline-flex items-center justify-center rounded-lg bg-primary text-primary-foreground py-3.5 px-4 hover:bg-primary/90 transition-colors font-bold shadow mt-2 hover:shadow-md active:scale-[0.98]"
                        >
                            Kirim Bukti Pembayaran
                        </button>
                    </form>
                </div>

                <!-- WhatsApp Fallback -->
                <div class="text-center mt-8">
                    <span class="text-xs text-muted-foreground bg-card px-2 font-medium uppercase tracking-wider relative -top-3">Atau</span>
                    <div class="">
                        <a
                            href={`https://wa.me/6285176777470?text=${encodeURIComponent(`Halo Tarjuman, saya sudah transfer untuk Order ID: ${order.id}. Ini buktinya:`)}`}
                            target="_blank"
                            class="inline-flex items-center justify-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-2.5 hover:bg-slate-50 hover:border-slate-300 transition-colors text-sm shadow-sm"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                            <span class="font-medium text-slate-700">Konfirmasi via WhatsApp</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    // Copy handling
    const copyBtns = document.querySelectorAll('.copy-btn');
    
    copyBtns.forEach(btn => {
        btn.addEventListener('click', async () => {
            const textToCopy = (btn as HTMLElement).dataset.copy || '';
            const copyIcon = btn.querySelector('.copy-icon');
            const checkIcon = btn.querySelector('.check-icon');
            
            try {
                await navigator.clipboard.writeText(textToCopy);
                
                // Visual feedback
                copyIcon?.classList.add('hidden');
                checkIcon?.classList.remove('hidden');
                
                setTimeout(() => {
                    copyIcon?.classList.remove('hidden');
                    checkIcon?.classList.add('hidden');
                }, 2000);
            } catch (err) {
                console.error('Failed to copy: ', err);
            }
        });
    });

    // Form submission feedback
    const form = document.querySelector('form');
    const submitBtn = form?.querySelector('button[type="submit"]');

    form?.addEventListener('submit', () => {
        if (!submitBtn) return;
        
        submitBtn.innerHTML = `
            <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            Mengunggah bukti...
        `;
        submitBtn.classList.add('opacity-80', 'cursor-not-allowed');
        
        // Disable button after short delay to prevent double submission
        setTimeout(() => {
            (submitBtn as HTMLButtonElement).disabled = true;
        }, 50);
    });
</script>
